{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wasmagent.dev/schemas/compliance/task-spec.schema.json",
  "title": "TaskSpec",
  "description": "Public contract for a compliance run. One TaskSpec → one run → one ComplianceEvalRecord.",
  "type": "object",
  "required": [
    "id",
    "intent",
    "language",
    "constraints",
    "priority_hierarchy"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 1,
      "description": "BCP-47 language tag (e.g. 'zh-CN', 'en')."
    },
    "audience": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "constraint-ir.schema.json"
      }
    },
    "priority_hierarchy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "system_policy",
          "user_explicit_constraints",
          "task_package_constraints",
          "tool_output_constraints",
          "history_constraints",
          "style_preferences"
        ]
      }
    },
    "tools": {
      "type": "object",
      "required": [
        "allowed"
      ],
      "properties": {
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "denied": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "repair": {
      "type": "object",
      "required": [
        "max_rounds",
        "default_strategy"
      ],
      "properties": {
        "max_rounds": {
          "type": "integer",
          "minimum": 0
        },
        "default_strategy": {
          "type": "string",
          "enum": [
            "patch",
            "insert_section",
            "regenerate_region",
            "full"
          ]
        }
      },
      "additionalProperties": false
    },
    "trace": {
      "type": "object",
      "required": [
        "record_constraint_eval",
        "record_tool_calls",
        "record_repairs"
      ],
      "properties": {
        "record_constraint_eval": {
          "type": "boolean"
        },
        "record_tool_calls": {
          "type": "boolean"
        },
        "record_repairs": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
