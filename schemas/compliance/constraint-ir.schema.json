{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wasmagent.dev/schemas/compliance/constraint-ir.schema.json",
  "title": "ConstraintIR",
  "description": "Typed, repairable, prioritised superset of @wasmagent/core Criterion. Canonical source for wasmagent-js and trace-pipeline.",
  "type": "object",
  "required": [
    "id",
    "description",
    "verify_method",
    "level",
    "priority",
    "category"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "verify_method": {
      "type": "string",
      "minLength": 1,
      "description": "Open string union — built-in verifiers register their own method names at runtime."
    },
    "arg": {},
    "path": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "hard",
        "soft"
      ]
    },
    "priority": {
      "type": "number",
      "description": "Higher wins inside a priority class (see TaskSpec.priority_hierarchy). Conventional band 0-100."
    },
    "category": {
      "type": "string",
      "enum": [
        "format",
        "content",
        "style",
        "tool",
        "state",
        "security",
        "semantic"
      ]
    },
    "repair": {
      "type": "object",
      "required": [
        "strategy"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "patch",
            "insert_section",
            "regenerate_region",
            "full"
          ]
        },
        "target_region": {
          "type": "string"
        },
        "max_rounds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
