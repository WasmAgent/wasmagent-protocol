{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wasmagent.dev/schemas/compliance/rollout-wire.schema.json",
  "title": "Rollout Wire Format",
  "description": "Intermediate JSONL formats in the wasmagent → evomerge data pipeline. Contains three related record types at different pipeline stages. NOT the final training record format — see training-record.schema.json. Validate individual records against the named entry schemas below: rollout-wire/v1/branch, rollout-wire/v1/dpo, rollout-wire/v1/ppo.",
  "oneOf": [
    {
      "$ref": "#/$defs/RolloutBranchRecord"
    },
    {
      "$ref": "#/$defs/DpoRecord"
    },
    {
      "$ref": "#/$defs/PpoRecord"
    }
  ],
  "$defs": {
    "RolloutBranchRecord": {
      "description": "Layer 1: RolloutBranchResult serialized to JSONL by RolloutForkRunner. Consumed by evomerge load_rollouts().",
      "type": "object",
      "required": [
        "rollout_id",
        "task",
        "branch_index",
        "temperature",
        "session_id",
        "tool_call_sequence",
        "final_answer"
      ],
      "additionalProperties": true,
      "properties": {
        "rollout_id": {
          "type": "string",
          "minLength": 1
        },
        "task": {
          "type": "string",
          "minLength": 1
        },
        "branch_index": {
          "type": "integer",
          "minimum": 0
        },
        "temperature": {
          "type": "number"
        },
        "session_id": {
          "type": "string"
        },
        "tool_call_sequence": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "final_answer": {
          "type": "string"
        },
        "build_result": {
          "type": [
            "object",
            "null"
          ]
        },
        "objective_score": {
          "type": "integer",
          "enum": [
            0,
            1
          ]
        },
        "objective_status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "unknown"
          ],
          "description": "Semantic label for objective_score. unknown = build not triggered (do not use in DPO pairs)."
        },
        "rank": {
          "type": "integer",
          "minimum": 0
        },
        "total_score": {
          "type": "number",
          "description": "Raw RolloutRanker totalScore, NOT normalized to [0,1]. Normalized by evomerge _compute_reward()."
        }
      }
    },
    "DpoProvenance": {
      "description": "Layer 2 DPO: provenance block from toDpoRecord().",
      "type": "object",
      "required": [
        "source",
        "rollout_id",
        "chosen_branch",
        "rejected_branch",
        "objective_score",
        "exported_at_ms",
        "n_gram_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "const": "wasmagent-rollout"
        },
        "rollout_id": {
          "type": "string",
          "minLength": 1
        },
        "chosen_branch": {
          "type": "integer",
          "minimum": 0
        },
        "rejected_branch": {
          "type": "integer",
          "minimum": 0
        },
        "objective_score": {
          "type": "object",
          "required": [
            "chosen",
            "rejected"
          ],
          "additionalProperties": false,
          "properties": {
            "chosen": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            },
            "rejected": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          }
        },
        "exported_at_ms": {
          "type": "integer",
          "minimum": 0
        },
        "n_gram_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$"
        }
      }
    },
    "PpoProvenance": {
      "description": "Layer 2 PPO: provenance block from toPpoRecords().",
      "type": "object",
      "required": [
        "source",
        "rollout_id",
        "branch_index",
        "objective_score",
        "exported_at_ms",
        "n_gram_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "const": "wasmagent-rollout"
        },
        "rollout_id": {
          "type": "string",
          "minLength": 1
        },
        "branch_index": {
          "type": "integer",
          "minimum": 0
        },
        "objective_score": {
          "type": "integer",
          "enum": [
            0,
            1
          ]
        },
        "exported_at_ms": {
          "type": "integer",
          "minimum": 0
        },
        "n_gram_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$"
        }
      }
    },
    "DpoRecord": {
      "description": "Layer 2 DPO: output of toDpoRecord(). Intermediate format before evomerge rebuilds messages.",
      "type": "object",
      "required": [
        "prompt",
        "chosen",
        "rejected",
        "tool_call_sequence",
        "provenance"
      ],
      "additionalProperties": true,
      "properties": {
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "chosen": {
          "type": "string",
          "minLength": 1
        },
        "rejected": {
          "type": "string",
          "minLength": 1
        },
        "tool_call_sequence": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "provenance": {
          "$ref": "#/$defs/DpoProvenance"
        }
      }
    },
    "PpoRecord": {
      "description": "Layer 2 PPO: output of toPpoRecords(). Intermediate format before evomerge rebuilds messages.",
      "type": "object",
      "required": [
        "prompt",
        "completion",
        "reward",
        "tool_call_sequence",
        "provenance"
      ],
      "additionalProperties": true,
      "properties": {
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "completion": {
          "type": "string"
        },
        "reward": {
          "type": "number",
          "description": "Raw totalScore from RolloutRanker, NOT normalized. Normalized to [0,1] by evomerge _compute_reward()."
        },
        "tool_call_sequence": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "provenance": {
          "$ref": "#/$defs/PpoProvenance"
        }
      }
    }
  }
}
